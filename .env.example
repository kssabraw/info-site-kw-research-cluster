# ============================================================================
# Environment Variables
# ============================================================================
# Copy this file to .env and fill in real values.
# Never commit .env to git (it's in .gitignore).
# ============================================================================

# ----------------------------------------------------------------------------
# Supabase
# ----------------------------------------------------------------------------
# Find these in your Supabase project settings:
# Project Settings → API → Project URL and service_role secret

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-secret-key

# Note: We use service_role key (not anon key) for CLI pipeline usage.
# service_role bypasses RLS, which is what we want for backend pipeline.
# When team UI is built, the UI will use anon key + auth.

# ----------------------------------------------------------------------------
# DataForSEO
# ----------------------------------------------------------------------------
# Login credentials from your DataForSEO dashboard

DATAFORSEO_LOGIN=your-dataforseo-email
DATAFORSEO_PASSWORD=your-dataforseo-password

# ----------------------------------------------------------------------------
# OpenAI (for embeddings)
# ----------------------------------------------------------------------------
# Create an API key at https://platform.openai.com/api-keys

OPENAI_API_KEY=sk-...

# ----------------------------------------------------------------------------
# Anthropic (for concept mapping and intent classification)
# ----------------------------------------------------------------------------
# Create an API key at https://console.anthropic.com/

ANTHROPIC_API_KEY=sk-ant-...

# ----------------------------------------------------------------------------
# Pipeline behavior
# ----------------------------------------------------------------------------
# Optional configuration that applies to all sites

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Cost guardrail: max USD per pipeline run (safety check)
# Pipeline will refuse to start if estimated cost exceeds this
MAX_RUN_COST_USD=100

# Default site to use if --site not specified on CLI
# Useful during development
DEFAULT_SITE_SLUG=

# ----------------------------------------------------------------------------
# Google Sheets (for Phase 12 review export)
# ----------------------------------------------------------------------------
# Service account credentials for writing review sheets
# Leave blank to skip Sheets export (use local CSV instead)

GOOGLE_SHEETS_CREDENTIALS_PATH=
GOOGLE_SHEETS_DEFAULT_FOLDER_ID=
