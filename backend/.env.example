# Backend environment (M1). On Railway, the Supabase values are inherited from
# the AR Tools project-level env (PRD §14.2). SUPABASE_ANON_KEY is service-
# specific and is required for the user-scoped (RLS-enforced) client.

SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Schema all this app's tables live under (PRD §14.3). Must be added to the
# project's PostgREST "Exposed schemas" in the Supabase dashboard.
FANOUT_SCHEMA=fanout

# OpenAI (silo discovery + embeddings) and DataForSEO. On Railway these are
# inherited from the AR Tools project-level env.
OPENAI_API_KEY=
OPENAI_SILO_MODEL=gpt-5.4
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Browsing tool type for the Responses API. Override if OpenAI's differs.
OPENAI_WEB_SEARCH_TOOL=web_search
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# M3 expansion tuning. Raise workers to finish faster; lower autocomplete_max to
# cut cost/time; time budget hard-caps a single expansion run (seconds).
EXPANSION_MAX_WORKERS=8
AUTOCOMPLETE_MAX=1500
EXPANSION_TIME_BUDGET_S=240

# Observability (PRD §16.3). INFO in prod, DEBUG during MVP testing.
LOG_LEVEL=INFO

# Comma-separated allowed frontend origins, or * for all.
CORS_ALLOW_ORIGINS=*
