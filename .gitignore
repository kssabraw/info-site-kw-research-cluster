# Secrets — never commit
.env
.env.*
!.env.example

# Service account credentials referenced by GOOGLE_SHEETS_CREDENTIALS_PATH
# in .env. Keep keyfiles out of git even if a developer points it at the
# repo path by mistake.
*.credentials.json
*service-account*.json

